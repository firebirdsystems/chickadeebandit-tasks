{
  "id": "tasks",
  "name": "Tasks",
  "version": "1.0.1",
  "description": "Create tasks with due dates, priorities, labels, recurrence, and subtasks. Assign to family members. Also syncs with Google Tasks and Apple Reminders.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "general",
  "tags": [
    "tasks",
    "reminders",
    "todo",
    "lists",
    "recurrence",
    "google",
    "apple"
  ],
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "nav": {
    "label": "Tasks"
  },
  "resource_limits": {
    "max_db_bytes": 104857600
  },
  "icon": "✅",
  "ai_access": {
    "allowed": true,
    "mode": "read_write",
    "db_exports": ["open_tasks", "overdue_tasks", "task_summary"],
    "db_mutations": ["complete_task", "reopen_task", "update_due_date", "reassign_task"],
    "db_inserts": ["add_task"]
  }
}
