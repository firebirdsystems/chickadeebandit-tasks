{
  "id": "tasks",
  "name": "Tasks",
  "version": "1.3.1",
  "description": "Create tasks with due dates, priorities, labels, recurrence, and subtasks. Assign to family members. Also syncs with Google Tasks and Apple Reminders.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "general",
  "tags": [
    "tasks",
    "reminders",
    "todo",
    "lists",
    "recurrence",
    "google",
    "apple"
  ],
  "contexts": ["household", "shared_space"],
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_encryption": "off",
  "db_plaintext_columns": ["due_date"],
  "row_policies": {
    "lists": {
      "kind": "owner_or_visibility",
      "member_column": "member_id",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_visibility_scoped": true
    },
    "tasks": {
      "kind": "owner_only",
      "member_column": "assignee_id"
    }
  },
  "nav": {
    "label": "Tasks"
  },
  "kiosk_quick_add": {
    "table": "inbox",
    "label": "Add a task",
    "text_column": "title",
    "normalized_column": "title_normalized",
    "actions": ["add"],
    "attribution": { "id_column": "added_by_id", "name_column": "added_by_name" },
    "created_at_column": "created_at"
  },
  "capture_consumer": { "kinds": ["task"], "via": "structured" },
  "agenda": {
    "kind": "task",
    "label": "Tasks",
    "source": {
      "kind": "sql",
      "query": "SELECT id AS id, title AS title, CASE WHEN due_time IS NULL OR due_time = '' THEN due_date ELSE due_date || 'T' || due_time END AS when_at, (completed = 1) AS done, NULLIF(notes, '') AS subtitle, NULLIF(assignee_id, '') AS member_id FROM app_tasks__tasks WHERE due_date = :today AND parent_id IS NULL ORDER BY completed, priority DESC, due_time LIMIT 20"
    }
  },
  "widget": {
    "label": "Tasks",
    "size": "small"
  },
  "resource_limits": {
    "max_db_bytes": 104857600
  },
  "icon": "✅",
  "ai_access": {
    "allowed": true,
    "mode": "read_write",
    "db_exports": ["open_tasks", "overdue_tasks", "task_summary"],
    "db_mutations": ["complete_task", "reopen_task", "update_due_date", "reassign_task"],
    "db_inserts": ["add_task"]
  }
}
