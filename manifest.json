    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "nav": { "label": "Tasks", "icon": "✅" },
  "resource_limits": {
    "max_db_bytes": 104857600
  }
}
